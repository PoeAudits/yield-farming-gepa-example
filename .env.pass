# Environment variables — generated by overlord env generate
# Format: ENV_VAR=pass:pass-entry-name
#
# To pull secrets into .env: overlord env
# To add literal values:     KEY=value

AI_ANTHROPIC_API_KEY=pass:ai/anthropic-api-key
AI_FIRMWARE_API_KEY=pass:ai/firmware-api-key
AI_HUGGING_FACE_TOKEN=pass:ai/hugging-face-token
AI_OLLAMA_API_KEY=pass:ai/ollama-api-key
AI_OPENAI_API_KEY=pass:ai/openai-api-key
AI_OPENCODE_API_KEY=pass:ai/opencode-api-key
AI_OPENROUTER_API_KEY=pass:ai/openrouter-api-key
DATA_ETHERSCAN_API_KEY=pass:data/etherscan-api-key
